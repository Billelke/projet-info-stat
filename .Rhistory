xlab="Pollution moyenne",
ylab="Force du vent",
main="Relation entre pollution et vent")
#Analyse graphique (nuages de points)
Le but est de visualiser la relation entre pollution et climat.
install.packages("ggplot2")
install.packages("corrplot")
table21 <- read.csv("pollution_climat_21.csv")
table22 <- read.csv("pollution_climat_22.csv")
table23 <- read.csv("pollution_climat_23.csv")
table24 <- read.csv("pollution_climat_24.csv")
head(table24)
plot(table24$moyenne_pollution,
table24$Tmax_med,
xlab="Pollution moyenne",
ylab="Température max",
main="Relation pollution - température")
plot(table24$moyenne_pollution,
table24$Force_vent_med,
xlab="Pollution moyenne",
ylab="Force du vent",
main="Relation pollution - vent")
plot(table24$moyenne_pollution,
table24$RR_med,
xlab="Pollution moyenne",
ylab="Précipitations",
main="Relation pollution - pluie")
cor(table24$moyenne_pollution,
table24$Tmax_med,
use="complete.obs")
cor(table24$moyenne_pollution,
table24$Force_vent_med,
use="complete.obs")
cor(table24$moyenne_pollution,
table24$RR_med,
use="complete.obs")
cor_matrix <- cor(table24[,c("moyenne_pollution",
"Tmax_med",
"Tmin_med",
"Force_vent_med",
"RR_med",
"Insolation_med",
"Rayonnement_med")],
use="complete.obs")
cor_matrix
corrplot(cor_matrix, method="circle")
plot(table24$moyenne_pollution,
table24$Tmax_med,
xlab="Pollution moyenne",
ylab="Température max",
main="Relation pollution - température")
